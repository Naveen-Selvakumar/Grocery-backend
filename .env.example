# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ────────────────────────────────────────────────
MONGO_URI=your_mongodb_connection_string

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

# ── Razorpay ──────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Email (Nodemailer) ────────────────────────────────────
# For Gmail: enable 2FA → generate App Password at https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── Frontend URL (for email links) ───────────────────────
CLIENT_URL=http://localhost:3000

# ── Google Cloud Vision (OCR) ────────────────────────────
# Option A (Vercel / production): paste the entire service-account JSON as one line
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"..."}
# Option B (local dev): place key file at backend/config/gen-lang-client-*.json (auto-detected)
